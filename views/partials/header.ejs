<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />

    <title>EMS Pro</title>

    <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <link rel="stylesheet" href="/assets/css/style.css" />
    <link rel="stylesheet" href="/assets/css/dashboard.css" />
    <link rel="stylesheet" href="/assets/css/animations.css" />
    <link rel="stylesheet" href="/assets/css/responsive.css" />
</head>

<body>

<div class="app-wrapper">

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">

        <div class="sidebar-brand">
            <i class="fa-solid fa-briefcase"></i>
            <span>EMS Pro</span>
        </div>

        <ul class="sidebar-menu">

            <!-- MAIN -->
            <li class="menu-title">Main</li>

            <% if(user.role === "admin"){ %>

                <li>
                    <a href="/admin/dashboard">
                        <i class="fa-solid fa-gauge-high"></i>
                        Admin Dashboard
                    </a>
                </li>

            <% } %>

            <% if(user.role === "hr"){ %>

                <li>
                    <a href="/hr/dashboard">
                        <i class="fa-solid fa-user-tie"></i>
                        HR Dashboard
                    </a>
                </li>

            <% } %>

            <% if(user.role === "employee"){ %>

                <li>
                    <a href="/employee/dashboard">
                        <i class="fa-solid fa-user"></i>
                        Employee Dashboard
                    </a>
                </li>

            <% } %>


            <!-- MANAGEMENT -->

            <% if(user.role === "admin" || user.role === "hr"){ %>

            <li class="menu-title">Management</li>

            <!-- Employees -->

            <li class="has-sub">

                <a href="#">
                    <i class="fa-solid fa-users"></i>
                    Employees
                    <i class="fa-solid fa-chevron-right arrow"></i>
                </a>

                <ul class="submenu">

                    <li>
                        <a href="/employee/all">
                            View All
                        </a>
                    </li>

                    <% if(user.role === "admin"){ %>

                    <li>
                        <a href="/admin/create-emp">
                            Add Employee
                        </a>
                    </li>

                    <li>
                        <a href="/employee/edit">
                            Edit Employee
                        </a>
                    </li>

                    <% } %>

                </ul>

            </li>

            <% } %>


            <!-- HR -->

            <% if(user.role === "admin"){ %>

            <li class="has-sub">

                <a href="#">
                    <i class="fa-solid fa-user-shield"></i>
                    HR
                    <i class="fa-solid fa-chevron-right arrow"></i>
                </a>

                <ul class="submenu">

                    <li>
                        <a href="/hr/all">
                            View HR
                        </a>
                    </li>

                    <li>
                        <a href="/admin/create-hr">
                            Add HR
                        </a>
                    </li>

                    <li>
                        <a href="/hr/edit">
                            Edit HR
                        </a>
                    </li>

                </ul>

            </li>

            <% } %>


            <!-- DEPARTMENT -->

            <% if(user.role === "admin"){ %>

            <li class="has-sub">

                <a href="#">
                    <i class="fa-solid fa-building"></i>
                    Departments
                    <i class="fa-solid fa-chevron-right arrow"></i>
                </a>

                <ul class="submenu">

                    <li>
                        <a href="/admin/view-dpt">
                            View
                        </a>
                    </li>

                    <li>
                        <a href="/admin/create-dpt">
                            Add
                        </a>
                    </li>

                    <li>
                        <a href="/department/edit">
                            Edit
                        </a>
                    </li>

                </ul>

            </li>

            <% } %>


            <!-- TASKS -->

            <li class="menu-title">Tasks</li>

            <li class="has-sub">

                <a href="#">
                    <i class="fa-solid fa-list-check"></i>
                    Tasks
                    <i class="fa-solid fa-chevron-right arrow"></i>
                </a>

                <ul class="submenu">

                    <li>
                        <a href="/task/view">
                            View Tasks
                        </a>
                    </li>

                    <% if(user.role === "admin" || user.role === "hr"){ %>

                    <li>
                        <a href="/task/create">
                            Create Task
                        </a>
                    </li>

                    <li>
                        <a href="/task/assign">
                            Assign Task
                        </a>
                    </li>

                    <li>
                        <a href="/task/edit">
                            Edit Task
                        </a>
                    </li>

                    <% } %>

                    <li>
                        <a href="/task/status">
                            Task Status
                        </a>
                    </li>

                    <li>
                        <a href="/task/my-task">
                            My Tasks
                        </a>
                    </li>

                    <li>
                        <a href="/task/update-status">
                            Update Status
                        </a>
                    </li>

                </ul>

            </li>


            <!-- ATTENDANCE -->

            <% if(user.role === "admin" || user.role === "hr"){ %>

            <li class="menu-title">
                Attendance & Leaves
            </li>

            <li>
                <a href="/attendance">
                    <i class="fa-solid fa-calendar-check"></i>
                    Attendance
                </a>
            </li>

            <li>
                <a href="/absent-employees">
                    <i class="fa-solid fa-user-xmark"></i>
                    Absent Employees
                </a>
            </li>

            <li>
                <a href="/manage-leaves">
                    <i class="fa-solid fa-plane-departure"></i>
                    Manage Leaves
                </a>
            </li>

            <li>
                <a href="/approve-leave">
                    <i class="fa-solid fa-check-double"></i>
                    Approve/Reject
                </a>
            </li>

            <% } %>


            <!-- EMPLOYEE LEAVE -->

            <% if(user.role === "employee"){ %>

            <li class="menu-title">
                Leave Section
            </li>

            <li>
                <a href="/apply-leave">
                    <i class="fa-solid fa-file-pen"></i>
                    Apply Leave
                </a>
            </li>

            <li>
                <a href="/my-leaves">
                    <i class="fa-solid fa-plane-departure"></i>
                    My Leaves
                </a>
            </li>

            <% } %>


            <!-- REPORTS -->

            <% if(user.role === "admin"){ %>

            <li class="menu-title">
                Reports
            </li>

            <li>
                <a href="/attendance-report">
                    <i class="fa-solid fa-chart-line"></i>
                    Attendance Report
                </a>
            </li>

            <li>
                <a href="/leave-report">
                    <i class="fa-solid fa-chart-pie"></i>
                    Leave Report
                </a>
            </li>

            <li>
                <a href="/salary-report">
                    <i class="fa-solid fa-money-bill-trend-up"></i>
                    Salary Report
                </a>
            </li>

            <li>
                <a href="/monthly-report">
                    <i class="fa-solid fa-chart-column"></i>
                    Monthly Report
                </a>
            </li>

            <li>
                <a href="/employee-performance">
                    <i class="fa-solid fa-trophy"></i>
                    Performance
                </a>
            </li>

            <% } %>


            <!-- ACCOUNT -->

            <li class="menu-title">
                Account
            </li>

            <li>
                <a href="/profile">
                    <i class="fa-solid fa-id-card"></i>
                    Profile
                </a>
            </li>

            <li>
                <a href="/edit-profile">
                    <i class="fa-solid fa-user-pen"></i>
                    Edit Profile
                </a>
            </li>

            <li>
                <a href="/change-password">
                    <i class="fa-solid fa-key"></i>
                    Change Password
                </a>
            </li>

            <li>
                <a href="/logout">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i>
                    Logout
                </a>
            </li>

        </ul>

        <div class="sidebar-footer">
            &copy; 2026 EMS Pro
        </div>

    </aside>


    <!-- MAIN CONTENT -->

    <div class="main-content">

        <!-- TOPBAR -->

        <header class="topbar">

            <button class="menu-toggle" id="menuToggle">
                <i class="fa-solid fa-bars"></i>
            </button>

            <div class="search-box">

                <i class="fa-solid fa-magnifying-glass"></i>

                <input type="text"
                    class="form-control"
                    placeholder="Search employees, tasks..." />

            </div>

            <div class="ms-auto d-flex align-items-center gap-2">

                <button class="topbar-icon" id="themeToggle">
                    <i class="fa-solid fa-moon"></i>
                </button>

                <button class="topbar-icon">
                    <i class="fa-solid fa-bell"></i>
                </button>

                <div class="dropdown">

                    <button class="user-avatar"
                        data-bs-toggle="dropdown">

                        <%= user.name%>

                    </button>

                    <div class="dropdown-menu dropdown-menu-end">

                        <div class="px-3 py-2 border-bottom">

                            <strong>
                                <%= user.name %>
                            </strong>

                            <div class="small text-muted text-capitalize">
                                <%= user.role %>
                            </div>

                        </div>

                        <a class="dropdown-item" href="/profile">

                            <i class="fa-solid fa-user me-2"></i>
                            Profile

                        </a>

                        <a class="dropdown-item" href="/edit-profile">

                            <i class="fa-solid fa-user-pen me-2"></i>
                            Edit Profile

                        </a>

                        <a class="dropdown-item text-danger"
                            href="/logout">

                            <i class="fa-solid fa-arrow-right-from-bracket me-2"></i>
                            Logout

                        </a>

                    </div>

                </div>

            </div>

        </header>

        <!-- PAGE CONTENT -->

        <div class="content-wrapper p-4">