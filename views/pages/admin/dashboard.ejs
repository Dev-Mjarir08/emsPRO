<%- include('../../partials/header.ejs') %>

<% if(user.role === "admin"){ %>

<main class="content-area fade-in">

    <div class="page-header">
        <div>

            <h1>Admin Dashboard</h1>

            <nav>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="#">Home</a>
                    </li>

                    <li class="breadcrumb-item active">
                        Dashboard
                    </li>
                </ol>
            </nav>

        </div>
    </div>

    <!-- STATS -->
    <div class="row g-4 mb-4">

        <div class="col-xl-3 col-md-6">
            <div class="stat-card">

                <div>
                    <p class="stat-label">Total Employees</p>
                    <h3 class="stat-value">248</h3>
                    <p class="stat-trend up">
                        ▲ +12% this month
                    </p>
                </div>

                <div class="stat-icon bg-grad-1">
                    <i class="fa-solid fa-users"></i>
                </div>

            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="stat-card">

                <div>
                    <p class="stat-label">Present Today</p>
                    <h3 class="stat-value">215</h3>
                    <p class="stat-trend up">
                        ▲ 87% attendance
                    </p>
                </div>

                <div class="stat-icon bg-grad-2">
                    <i class="fa-solid fa-user-check"></i>
                </div>

            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="stat-card">

                <div>
                    <p class="stat-label">Monthly Payroll</p>
                    <h3 class="stat-value">$148K</h3>
                    <p class="stat-trend up">
                        ▲ +5.2%
                    </p>
                </div>

                <div class="stat-icon bg-grad-3">
                    <i class="fa-solid fa-money-bill-wave"></i>
                </div>

            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="stat-card">

                <div>
                    <p class="stat-label">Pending Leaves</p>
                    <h3 class="stat-value">18</h3>
                    <p class="stat-trend down">
                        ▼ -3 vs last week
                    </p>
                </div>

                <div class="stat-icon bg-grad-4">
                    <i class="fa-solid fa-plane"></i>
                </div>

            </div>
        </div>

    </div>

</main>

<% } %>

<%- include('../../partials/footer.ejs') %>